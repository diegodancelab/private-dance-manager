# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string. Used by the app (via PrismaPg adapter)
# and by the Prisma CLI (prisma migrate, prisma db seed).
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# - Local dev:  point to the Docker Compose container (see below)
# - Vercel dev/preprod/prod: set this per-environment in the Vercel dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/private_dance_manager

# ─── Production Bootstrap (run once to create the first teacher account) ─────
# Used by: npm run bootstrap:prod
# Run locally, pointing DATABASE_URL at the production database.
# Never set these on Vercel — they are only for the one-time bootstrap command.
#
# BOOTSTRAP_EMAIL=you@example.com
# BOOTSTRAP_PASSWORD=<strong-password-min-12-chars>
# BOOTSTRAP_FIRST_NAME=Diego
# BOOTSTRAP_LAST_NAME=Poli
# BOOTSTRAP_PHONE=+41000000000

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Used to send security alerts (e.g. too many failed login attempts).
# RESEND_API_KEY: get it from resend.com/api-keys
# ALERT_FROM_EMAIL: must be a verified domain on Resend (or onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ─── Docker Compose (local development only) ─────────────────────────────────
# These variables configure the local PostgreSQL container started with
# `docker compose up -d`. They must match the credentials in DATABASE_URL above.
# They are NOT used by Vercel — only by docker-compose.yml.
POSTGRES_DB=private_dance_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
