generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum LessonType {
  PRIVATE
  DUO
  GROUP
  ONLINE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum ChargeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELED
}

enum ChargeType {
  LESSON
  PACKAGE
  ADJUSTMENT
  OTHER
}

enum PaymentMethod {
  CASH
  TWINT
  BANK_TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
}

enum PackageStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELED
}

model User {
  id                 String              @id @default(cuid())
  email              String?             @unique
  firstName          String
  lastName           String
  phone              String?
  role               UserRole            @default(STUDENT)
  isActive           Boolean             @default(true)
  passwordHash       String?
  createdByTeacherId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  taughtLessons         Lesson[]            @relation("TeacherLessons")
  bookings              LessonParticipant[]
  charges               Charge[]            @relation("ChargeStudent")
  taughtCharges         Charge[]            @relation("ChargeTeacher")
  payments              Payment[]           @relation("PaymentStudent")
  taughtPayments        Payment[]           @relation("PaymentTeacher")
  progressEntries       ProgressEntry[]     @relation("ProgressEntryStudent")
  taughtProgressEntries ProgressEntry[]     @relation("ProgressEntryTeacher")
  packages              Package[]           @relation("PackageStudent")
  taughtPackages        Package[]           @relation("PackageTeacher")
  sessions              Session[]
  createdByTeacher      User?               @relation("TeacherCreatedStudents", fields: [createdByTeacherId], references: [id])
  createdStudents       User[]              @relation("TeacherCreatedStudents")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lesson {
  id            String              @id @default(cuid())
  title         String
  description   String?
  lessonType    LessonType
  scheduledAt   DateTime
  durationMin   Int
  priceAmount   Decimal?            @db.Decimal(10, 2)
  location      String?
  teacherId     String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  teacher       User                @relation("TeacherLessons", fields: [teacherId], references: [id])
  participants  LessonParticipant[]
  charges       Charge[]
}

model LessonParticipant {
  id         String         @id @default(cuid())
  lessonId   String
  userId     String
  status     BookingStatus  @default(CONFIRMED)
  createdAt  DateTime       @default(now())

  lesson        Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageUsage  PackageUsage?

  @@unique([lessonId, userId])
}

model ProgressEntry {
  id         String    @id @default(cuid())
  userId     String
  teacherId  String
  title      String
  notes      String?
  level      Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User       @relation("ProgressEntryStudent", fields: [userId], references: [id], onDelete: Cascade)
  teacher    User       @relation("ProgressEntryTeacher", fields: [teacherId], references: [id])
}

model Charge {
  id            String              @id @default(cuid())
  userId        String
  teacherId     String
  lessonId      String?
  type          ChargeType          @default(LESSON)
  title         String
  description   String?
  amount        Decimal             @db.Decimal(10, 2)
  currency      String              @default("CHF")
  status        ChargeStatus        @default(PENDING)
  dueAt         DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation("ChargeStudent", fields: [userId], references: [id], onDelete: Cascade)
  teacher       User                @relation("ChargeTeacher", fields: [teacherId], references: [id])
  lesson        Lesson?             @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  allocations   PaymentAllocation[]
  package       Package?
}

model Payment {
  id            String              @id @default(cuid())
  userId        String
  teacherId     String
  amount        Decimal             @db.Decimal(10, 2)
  currency      String              @default("CHF")
  method        PaymentMethod?
  status        PaymentStatus       @default(COMPLETED)
  note          String?
  paidAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation("PaymentStudent", fields: [userId], references: [id], onDelete: Cascade)
  teacher       User                @relation("PaymentTeacher", fields: [teacherId], references: [id])
  allocations   PaymentAllocation[]
}

model PaymentAllocation {
  id            String    @id @default(cuid())
  chargeId      String
  paymentId     String
  amount        Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())

  charge        Charge    @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  payment       Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([chargeId, paymentId])
}

model Package {
  id               String        @id @default(cuid())
  userId           String
  teacherId        String
  chargeId         String?       @unique
  name             String
  totalMinutes     Int
  remainingMinutes Int
  status           PackageStatus @default(ACTIVE)
  expiresAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation("PackageStudent", fields: [userId], references: [id], onDelete: Cascade)
  teacher          User          @relation("PackageTeacher", fields: [teacherId], references: [id])
  charge           Charge?       @relation(fields: [chargeId], references: [id], onDelete: SetNull)
  usages           PackageUsage[]
}

model PackageUsage {
  id                  String            @id @default(cuid())
  packageId           String
  lessonParticipantId String            @unique
  minutesConsumed     Int
  createdAt           DateTime          @default(now())

  package             Package           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  lessonParticipant   LessonParticipant @relation(fields: [lessonParticipantId], references: [id], onDelete: Cascade)
}