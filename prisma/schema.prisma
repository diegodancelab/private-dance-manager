generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum LessonType {
  PRIVATE
  DUO
  GROUP
  ONLINE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum ChargeStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELED
}

enum ChargeType {
  LESSON
  PACKAGE
  ADJUSTMENT
  OTHER
}

enum PaymentMethod {
  CASH
  TWINT
  BANK_TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELED
  REFUNDED
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  firstName       String
  lastName        String
  phone           String?
  role            UserRole            @default(STUDENT)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  taughtLessons   Lesson[]            @relation("TeacherLessons")
  bookings        LessonParticipant[]
  charges         Charge[]
payments        Payment[]
  progressEntries ProgressEntry[]
}

model Lesson {
  id            String              @id @default(cuid())
  title         String
  description   String?
  lessonType    LessonType
  scheduledAt   DateTime
  durationMin   Int
  priceAmount   Decimal?            @db.Decimal(10, 2)
  location      String?
  teacherId     String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  teacher       User                @relation("TeacherLessons", fields: [teacherId], references: [id])
  participants  LessonParticipant[]
  charges       Charge[]
}

model LessonParticipant {
  id         String         @id @default(cuid())
  lessonId   String
  userId     String
  status     BookingStatus  @default(CONFIRMED)
  createdAt  DateTime       @default(now())

  lesson     Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
}

model ProgressEntry {
  id         String    @id @default(cuid())
  userId     String
  title      String
  notes      String?
  level      Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Charge {
  id            String              @id @default(cuid())
  userId        String
  lessonId      String?
  type          ChargeType          @default(LESSON)
  title         String
  description   String?
  amount        Decimal             @db.Decimal(10, 2)
  currency      String              @default("CHF")
  status        ChargeStatus        @default(PENDING)
  dueAt         DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson        Lesson?             @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  allocations   PaymentAllocation[]
}

model Payment {
  id            String              @id @default(cuid())
  userId        String
  amount        Decimal             @db.Decimal(10, 2)
  currency      String              @default("CHF")
  method        PaymentMethod?
  status        PaymentStatus       @default(COMPLETED)
  note          String?
  paidAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations   PaymentAllocation[]
}

model PaymentAllocation {
  id            String    @id @default(cuid())
  chargeId      String
  paymentId     String
  amount        Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())

  charge        Charge    @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  payment       Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([chargeId, paymentId])
}